{
  "expo": {
    "name": "8bit Sleep",
    "slug": "8bit-sleep",
    "version": "0.1.0",
    "scheme": "eightbitsleep",
    "orientation": "portrait",
    "icon": "./assets/pixellab/root/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#221812",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eightbitsleep.app"
    },
    "android": {
      "package": "com.eightbitsleep.app",
      "adaptiveIcon": {
        "backgroundColor": "#221812",
        "foregroundImage": "./assets/pixellab/root/android-icon-foreground.png",
        "backgroundImage": "./assets/pixellab/root/android-icon-background.png",
        "monochromeImage": "./assets/pixellab/root/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/pixellab/root/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Scan your Quote e-ink device to connect it to 8bit Sleep."
        }
      ]
    ],
    "splash": {
      "image": "./assets/pixellab/root/splash-icon.png",
      "backgroundColor": "#221812"
    }
  }
}
