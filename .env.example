POSTGRES_USER=bitsleep
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bitsleep
BACKEND_PORT=8080

# Raids (P2, FLAGS.raids) — the app's own Go + Postgres backend (see backend/,
# compose.yaml). Point this at the backend reachable from the phone; on a LAN
# demo use the host machine's IP, not localhost. Unset → raids are a silent
# no-op and solo play is unaffected.
EXPO_PUBLIC_API_URL=http://192.168.1.10:8080

# PixelLab AI (https://www.pixellab.ai/account) — offline asset generation via
# tools/pixellab_gen.py. Not used by the app itself at runtime.
PIXELLAB_SECRET=your-pixellab-api-key
